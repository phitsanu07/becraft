# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
APP_NAME=becraft-app

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/becraft?schema=public

# Cache + Queue (Redis)
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=replace-with-32-byte-random-string
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Bcrypt
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3000

# Optional: Sentry error tracking
# SENTRY_DSN=

# Optional: OpenTelemetry tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
